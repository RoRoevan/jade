<?php

namespace App\Http\Controllers;

use App\Models\Reward;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Auth;
use Inertia\Inertia;

class RedeemController extends Controller
{
    /**
     * Show the redeem page.
     * Rewards now come from the database (managed via the Admin panel).
     */
    public function index()
    {
        $user    = Auth::user();
        $rewards = Reward::orderBy('points_required')->get();

        return Inertia::render('Redeem', [
            'user'    => $user,
            'rewards' => $rewards,
        ]);
    }

    /**
     * Claim a reward by its ID.
     * Deducts the required points from the authenticated user.
     */
    public function claim(Request $request)
    {
        $request->validate([
            'reward_id' => 'required|integer|exists:rewards,id',
        ]);

        $user   = Auth::user();
        $reward = Reward::findOrFail($request->reward_id);

        if ($user->points < $reward->points_required) {
            return back()->with('error', 'Not enough points to redeem this reward.');
        }

        $user->points -= $reward->points_required;
        $user->save();

        return back()->with('status', "You have successfully redeemed: {$reward->name}!");
    }
}